# =============================================================================
# 1891 Interpreter — .htaccess
# Deployed to public_html/interpreter/ (madeby1891.com/interpreter)
# Per FDT-audit baseline (root CLAUDE.md): block /deployment/, real 404,
# security headers, no soft 404.
# =============================================================================

Options -Indexes -MultiViews
DirectoryIndex index.html

# --- Real 404 (NOT a soft-200 redirect) -------------------------------------
ErrorDocument 404 /interpreter/404.html

# --- Block any /deployment/ paths from serving publicly ----------------------
RedirectMatch 403 ^/interpreter/deployment(/|$)
RedirectMatch 403 ^/interpreter/_build(/|$)
RedirectMatch 403 ^/interpreter/\.git(/|$)
RedirectMatch 403 ^/interpreter/\.env(\.|$)
RedirectMatch 403 ^/interpreter/.*-secret(\.js|\.json|\.gs)$
RedirectMatch 403 ^/interpreter/CLAUDE\.md$
RedirectMatch 403 ^/interpreter/HANDOFF\.md$
RedirectMatch 403 ^/interpreter/DISASTER_RECOVERY\.md$
RedirectMatch 403 ^/interpreter/godview\.json$

# --- HTTPS + canonical host --------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force HTTPS
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !=https
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Strip www
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]
</IfModule>

# --- Security headers --------------------------------------------------------
<IfModule mod_headers.c>
  # HSTS preload (host-wide; only set here if /interpreter is the only path
  # served — otherwise set at the umbrella host level)
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"

  # Click-jacking
  Header always set X-Frame-Options "DENY"

  # MIME sniffing
  Header always set X-Content-Type-Options "nosniff"

  # Referrer
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Browser permissions (deny the things this site never needs)
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()"

  # CSP — strict for marketing site. No external scripts, no external fonts,
  # no iframes. If you need to add a vendor (e.g. a video host), tighten the
  # source list rather than relaxing wholesale.
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' https://script.google.com https://script.googleusercontent.com; frame-ancestors 'none'; form-action 'self' https://script.google.com https://script.googleusercontent.com; base-uri 'self'; object-src 'none'; upgrade-insecure-requests"

  # CSP report endpoint (placeholder — replace with real reporting endpoint
  # once provisioned). Browsers ignore an unreachable report-to gracefully.
  Header always set Reporting-Endpoints 'csp-endpoint="/interpreter/api/csp-report"'

  # Don't leak server software
  Header always unset Server
  Header always unset X-Powered-By
</IfModule>

# --- Caching -----------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — short cache, frequent updates
  ExpiresByType text/html "access plus 5 minutes"

  # CSS/JS — versioned via filename in future; for now, 1 hour
  ExpiresByType text/css "access plus 1 hour"
  ExpiresByType application/javascript "access plus 1 hour"

  # Images / SVG — long
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"

  # Sitemap, robots
  ExpiresByType application/xml "access plus 1 hour"
  ExpiresByType text/plain "access plus 1 day"
</IfModule>

# --- Compression -------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml application/xml application/javascript image/svg+xml
</IfModule>

# --- MIME types --------------------------------------------------------------
<IfModule mod_mime.c>
  AddType image/svg+xml .svg
  AddType application/xml .xml
</IfModule>

# --- Disallow access to source/text artifacts -------------------------------
<FilesMatch "\.(md|py|sh|log|bak|swp|orig)$">
  Require all denied
</FilesMatch>
